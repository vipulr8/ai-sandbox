#!/bin/bash
# Strip any Claude/Anthropic attribution from commit messages

MSG_FILE="$1"

# Remove Co-Authored-By lines referencing Claude or Anthropic
sed -i '/^Co-[Aa]uthored-[Bb]y:.*[Cc]laude/d' "$MSG_FILE"
sed -i '/^Co-[Aa]uthored-[Bb]y:.*[Aa]nthropic/d' "$MSG_FILE"
sed -i '/^Co-[Aa]uthored-[Bb]y:.*noreply@anthropic\.com/d' "$MSG_FILE"

# Remove "Generated with Claude" / "Generated by Claude" lines
sed -i '/[Gg]enerated with [Cc]laude/d' "$MSG_FILE"
sed -i '/[Gg]enerated by [Cc]laude/d' "$MSG_FILE"

# Remove trailing blank lines left behind
sed -i -e :a -e '/^\n*$/{$d;N;ba}' "$MSG_FILE"

exit 0
