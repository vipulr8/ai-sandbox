{
  "name": "ai-sandbox",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "claude",
  "workspaceFolder": "/home/coder/project",
  "remoteUser": "coder",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "workbench.colorTheme": "Monokai"
      },
      "extensions": [
        "ms-python.python",
        "ms-python.debugpy",
        "charliermarsh.ruff",
        "hashicorp.terraform",
        "redhat.vscode-yaml",
        "ZainChen.json",
        "eamodio.gitlens"
      ]
    }
  }
}
